{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "dev-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "vite",
        "dev"
      ],
      "autoPort": true,
      "port": 3177,
      "env": {
        "NO_DEVTOOLS": "1"
      }
    }
  ]
}